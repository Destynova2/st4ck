# ─── VMware Airgap Environment Variables ────────────────────────────────────
# Source this file or export these variables before running scripts.

# Talos / Kubernetes versions
export TALOS_VERSION="v1.12.4"
export KUBERNETES_VERSION="1.35.0"
export IMAGER_IMAGE="ghcr.io/siderolabs/imager:${TALOS_VERSION}"

# Cilium versions
export CILIUM_VERSION="1.17.13"

# Architecture
export ARCH="amd64"

# Cluster endpoint (VIP shared between control planes)
export CLUSTER_ENDPOINT="https://192.168.100.10:6443"
export CLUSTER_NAME="vmware-airgap"

# Network configuration — adapt to your environment
export VIP="192.168.100.10"
export GATEWAY="192.168.100.1"
export DNS="192.168.100.2"
export NETMASK="24"

# Node IPs (space-separated)
export CP_IPS="192.168.100.11 192.168.100.12 192.168.100.13"
export WRK_IPS="192.168.100.21 192.168.100.22 192.168.100.23"

# Disk for Talos install
export INSTALL_DISK="/dev/sda"

# Output directory
export OUT_DIR="_out"
