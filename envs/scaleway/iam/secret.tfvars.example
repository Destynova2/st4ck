# Copy to secret.tfvars and fill with your Scaleway admin credentials.
# This file is gitignored — NEVER commit secret.tfvars.

scw_access_key      = "SCWxxxxxxxxxxxxxxxxx"
scw_secret_key      = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
scw_organization_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Optional overrides:
# namespace           = "st4ck"
# env_classes         = ["dev", "staging", "prod"]
# ssh_public_key_path = "~/.ssh/talos_scaleway.pub"
# owner               = "ludwig"

# Claude/AI scoped IAM apps — strict isolation from other org projects.
# enable_claude_apps       = true   # default: creates claude-readonly
# enable_claude_writeable  = false  # set true to also create claude-writeable (use with denylist)
# claude_readonly_include_iam = false  # set true if you need Claude to list IAM (leaks org structure)
