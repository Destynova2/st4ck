# Talos secrets - NEVER commit
**/talosconfig
**/secrets.yaml
**/*.secret
**/*.key
**/*.pem

# Generated machine configs (contain secrets)
_out/
*.kubeconfig

# Terraform tfvars (may contain secrets)
**/terraform.tfvars
**/secret.tfvars

# Terraform state (pass1 #1: NEVER commit — exposes secrets even after git rm)
**/.terraform/
**/terraform.tfstate
**/terraform.tfstate.*
**/*.tfstate
**/*.tfstate.*
**/.terraform.lock.hcl

# KMS bootstrap outputs (secrets)
kms-output/

# Fetched Helm charts (upstream dependencies)
stacks/storage/chart/
stacks/storage/chart-local-path/

# Arbor staging tree (pre-pulled images + charts)
arbor/

# Build artifacts
image-cache.oci
*.ova
*.iso
*.raw
*.qcow2
*.zst

# Image lists (may be regenerated)
images.txt

# OS / IDE
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# OpenTofu local-backend overlay (generated by Makefile during chicken-and-egg
# bootstrap and destroy of the CI VM — never commit).
**/_local_backend_override.tf
envs/scaleway/ci/files/
